---
import Layout from "../layouts/Layout.astro";
import {
	APPROVED_MEMBER_STATES,
	DUTCH_APPROVAL_DATE,
	DUTCH_APPROVAL_MOMENT,
	EU_ROAD_DEATHS_2025,
	PROCESS_STARTED_APPROX,
	PROCESS_STARTED_MOMENT,
	REPORTED_TCMV_EARLIEST_VOTE_DATE,
	REPORTED_TCMV_PRESENTATION_DATE,
	SITE_DOMAIN,
	SITE_DESCRIPTION,
	SITE_TITLE,
	TODAY_ISO,
	countries,
	daysBetween,
	defaultScenario,
	fleetScopes,
	getFleetScope,
	institutionTrack,
	methodology,
	rankCountries,
	sources,
	sumEstimatedLives,
	timeline,
	type CountryOpportunity,
} from "../data/eu";

const initialRanking = rankCountries(defaultScenario);
const initialTotal = sumEstimatedLives(initialRanking);
const approvalWaitDays = daysBetween(DUTCH_APPROVAL_DATE, TODAY_ISO);
const processDays = daysBetween(PROCESS_STARTED_APPROX, TODAY_ISO);
const pendingMemberStates = countries.length - APPROVED_MEMBER_STATES;
const initialLeader = initialRanking[0];
const approvalInitial = (initialTotal / 365) * approvalWaitDays;
const processInitial = (initialTotal / 365) * processDays;
const initialDaily = initialTotal / 365;
const reportedPresentationDelayDays = daysBetween(
	DUTCH_APPROVAL_DATE,
	REPORTED_TCMV_PRESENTATION_DATE,
);
const reportedVoteDelayDays = daysBetween(
	DUTCH_APPROVAL_DATE,
	REPORTED_TCMV_EARLIEST_VOTE_DATE,
);
const initialReportedVoteDelay = initialDaily * reportedVoteDelayDays;
const initialScope = getFleetScope(defaultScenario.approvalScopeKey);
const initialScopeComparisons = fleetScopes.map((scope) => {
	const rows = rankCountries({
		...defaultScenario,
		approvalScopeKey: scope.key,
	});

	return {
		...scope,
		total: sumEstimatedLives(rows),
	};
});
const initialLatestScopeTotal =
	initialScopeComparisons.find((scope) => scope.key === "latest-only")?.total ?? 1;

const formatWhole = new Intl.NumberFormat("en-US");
const formatLives = new Intl.NumberFormat("en-US", {
	minimumFractionDigits: 1,
	maximumFractionDigits: 1,
});

const renderStatusLabel = (row: CountryOpportunity) =>
	row.approval === "national-approval" ? "Live in NL" : "Pending EU vote";

const renderStatusClass = (row: CountryOpportunity) =>
	row.approval === "national-approval"
		? "status-badge status-badge--live"
		: "status-badge status-badge--pending";
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main class="page-shell">
		<section class="panel hero hero--clock">
			<div class="hero__copy">
				<p class="eyebrow">{SITE_TITLE} • {SITE_DOMAIN}</p>
				<h1>
					The clock is
					<span class="accent">still running.</span>
				</h1>
				<p class="lead">
					RDW approved Tesla FSD Supervised in the Netherlands on 10 April 2026
					after roughly 18 months of testing. RDW also says EU-wide validity
					still needs a European Commission step and a member-state vote. This
					page turns that delay into a live scenario clock with visible,
					editable assumptions instead of hiding the cost inside policy prose.
				</p>
				<div class="hero__warning">
					This is an institutional accountability tracker, not a legal-liability
					board. The live numbers below are scenario estimates, not verified body
					counts. They are there to make delay legible, not to fabricate blame.
				</div>
			</div>

			<div class="counter-wall">
				<div class="counter-wall__live">
					<span class="counter-wall__dot"></span>
					<span>Live scenario counter</span>
				</div>
				<p class="counter-wall__eyebrow">
					Illustrative lives left on the table since the RDW/Tesla testing
					programme began
				</p>
				<strong class="counter-wall__value" id="realtime-process-counter">
					{formatLives.format(processInitial)}
				</strong>
				<div class="impact-stage" id="impact-stage" aria-hidden="true">
					<div class="impact-stage__road"></div>
					<div class="impact-stage__barrier"></div>
					<div class="impact-stage__countdown">
						<span class="impact-stage__countdown-label">Next +1</span>
						<strong class="impact-stage__countdown-value" id="impact-next-timer">
							{Math.max(0, Math.floor(365 / initialTotal))}d
						</strong>
					</div>
					<div class="impact-stage__burst">!</div>
					<div class="impact-stage__stamp" id="impact-stage-stamp">+1</div>
					<div class="impact-stage__car">
						<span class="impact-stage__roof"></span>
						<span class="impact-stage__wheel impact-stage__wheel--rear"></span>
						<span class="impact-stage__wheel impact-stage__wheel--front"></span>
					</div>
				</div>
				<p class="counter-wall__caption">
					Approximate counter from October 2024 under the current slider values
					and <span id="selected-scope-copy">{initialScope.label}</span>.
				</p>
				<div class="counter-wall__rail">
					<div class="counter-tile">
						<span class="counter-tile__label">Since Dutch approval</span>
						<strong class="counter-tile__value" id="realtime-approval-counter">
							{formatLives.format(approvalInitial)}
						</strong>
					</div>
					<div class="counter-tile">
						<span class="counter-tile__label">Current rate</span>
						<strong class="counter-tile__value" id="realtime-rate">
							{formatLives.format(initialTotal / 365)}
						</strong>
					</div>
					<div class="counter-tile">
						<span class="counter-tile__label">Current bottleneck</span>
						<strong class="counter-tile__value">
							{pendingMemberStates}/27
						</strong>
					</div>
					<div class="counter-tile">
						<span class="counter-tile__label">EU road deaths in 2025</span>
						<strong class="counter-tile__value">
							{formatWhole.format(EU_ROAD_DEATHS_2025)}
						</strong>
					</div>
				</div>
				<p class="counter-wall__footnote">
					RDW says national validity started on 10 April 2026. RDW also says
					EU-wide validity still needs a Commission step and a member-state vote.
				</p>
			</div>
		</section>

		<section class="panel">
			<div class="section-head">
				<p class="eyebrow">Scenario model</p>
				<h2>The upside you freeze when you wait</h2>
				<p>
					The controls below are intentionally exposed. Change the assumed Tesla
					share inside the BEV fleet and the assumed fatal-risk reduction to see
					how the country ladder moves.
				</p>
			</div>

			<div class="controls">
				<div class="control">
					<label for="tesla-share">
						<span class="control__head">
							<span>Tesla share inside the BEV fleet</span>
							<strong id="tesla-share-value">
								{defaultScenario.teslaShareWithinBev}%
							</strong>
						</span>
						<input
							id="tesla-share"
							type="range"
							min="5"
							max="40"
							step="1"
							value={defaultScenario.teslaShareWithinBev}
						/>
						<small>
							Proxy input. The site uses official BEV fleet share by country, then
							applies this adjustable Tesla slice inside that BEV fleet.
						</small>
					</label>
				</div>

				<div class="control">
					<label for="safety-gain">
						<span class="control__head">
							<span>Assumed fatal-risk reduction</span>
							<strong id="safety-gain-value">{defaultScenario.safetyGain}%</strong>
						</span>
						<input
							id="safety-gain"
							type="range"
							min="10"
							max="60"
							step="1"
							value={defaultScenario.safetyGain}
						/>
						<small>
							Scenario input, not a clinical certainty. It represents the share of
							fatal outcomes avoided within the currently addressable slice of the
							fleet.
						</small>
					</label>
				</div>

				<div class="control control--scope">
					<div class="control__head">
						<span>Approval scope</span>
						<strong id="approval-scope-value">{initialScope.label}</strong>
					</div>
					<div class="scope-picker" role="radiogroup" aria-label="Approval scope">
						{
							fleetScopes.map((scope) => (
								<button
									type="button"
									class:list={[
										"scope-button",
										scope.key === defaultScenario.approvalScopeKey && "is-active",
									]}
									data-scope-key={scope.key}
									aria-pressed={scope.key === defaultScenario.approvalScopeKey
										? "true"
										: "false"}
								>
									<span>{scope.label}</span>
									<small>{scope.coverageShare}% of Tesla fleet in scope</small>
								</button>
							))
						}
					</div>
					<small>
						Explicit scenario assumption. The point is to show how much bigger
						the upside gets when approval reaches the broad HW3 and HW4 installed
						base instead of a token slice of the newest cars.
					</small>
				</div>
			</div>

			<div class="formula">
				<strong>Formula:</strong>
				<code>
					2023 road deaths × 2024 BEV fleet share × Tesla share inside BEVs ×
					selected Tesla hardware scope × assumed fatal-risk reduction
				</code>
			</div>

			<div class="section-head section-head--compact">
				<p class="eyebrow">Hardware scope</p>
				<h2>The biggest win lands when HW3 and HW4 are both in scope</h2>
				<p>
					Same country data. Same safety assumption. The difference below is only
					how much of the Tesla fleet policy actually unlocks.
				</p>
			</div>

			<div class="scope-grid">
				{
					initialScopeComparisons.map((scope) => (
						<article
							class:list={[
								"scope-card",
								scope.key === defaultScenario.approvalScopeKey && "is-active",
							]}
							data-scope-card={scope.key}
						>
							<span class="scope-card__label">{scope.label}</span>
							<strong
								class="scope-card__value"
								id={`scope-${scope.key}-value`}
							>
								{formatLives.format(scope.total)}
								<span class="unit">lives/yr</span>
							</strong>
							<p class="scope-card__meta">
								{scope.coverageShare}% of the Tesla fleet in scope
							</p>
							<p class="scope-card__note">{scope.explainer}</p>
							<p
								class="scope-card__multiplier"
								id={`scope-${scope.key}-multiplier`}
							>
								{
									scope.key === "latest-only"
										? "Baseline"
										: `${formatLives.format(scope.total / initialLatestScopeTotal)}x newest-only`
								}
							</p>
						</article>
					))
				}
			</div>

			<div class="summary-grid">
				<article class="score-card">
					<span class="score-card__label">Illustrative annual upside</span>
					<strong class="score-card__value" id="annual-upside">
						{formatLives.format(initialTotal)}
						<span class="unit">lives/yr</span>
					</strong>
					<p>
						Across the EU under <span id="annual-upside-scope">{initialScope.label}</span>.
					</p>
				</article>
				<article class="score-card">
					<span class="score-card__label">Since testing began</span>
					<strong class="score-card__value" id="since-process">
						{formatLives.format(processInitial)}
						<span class="unit">lives</span>
					</strong>
					<p>Approximate cumulative upside since the RDW testing window began.</p>
				</article>
				<article class="score-card">
					<span class="score-card__label">Since Dutch approval</span>
					<strong class="score-card__value" id="since-approval">
						{formatLives.format(approvalInitial)}
						<span class="unit">lives</span>
					</strong>
					<p>
						Over the <span id="approval-days">{approvalWaitDays}</span> days since
						10 April 2026.
					</p>
				</article>
				<article class="score-card">
					<span class="score-card__label">Largest frozen opportunity</span>
					<strong class="score-card__value" id="leader-country">
						{initialLeader.name}
					</strong>
					<p>
						<span id="leader-value">{formatLives.format(initialLeader.estimatedLivesPerYear)}</span>
						illustrative lives/year under <span id="leader-scope">{initialScope.label}</span>.
					</p>
				</article>
			</div>
		</section>

		<section class="panel">
			<div class="section-head">
				<p class="eyebrow">Decision test</p>
				<h2>What Europe wins by allowing FSD now, and what waiting really buys</h2>
				<p>
					This is the policy trade. Fast approval has operational and political
					risk. Waiting has operational and political risk too. The difference is
					that waiting keeps the upside frozen while the clock keeps moving.
				</p>
			</div>

			<div class="decision-grid">
				<article class="decision-card decision-card--go">
					<span class="decision-card__kicker">Allow Today</span>
					<h3>What they win</h3>
					<ul class="decision-list">
						<li>
							Unlock
							<strong id="decision-allow-annual">
								{formatLives.format(initialTotal)} lives/yr
							</strong>
							of illustrative upside under <span id="decision-allow-scope">{initialScope.label}</span>.
						</li>
						<li>
							Stop the delay clock adding about
							<strong id="decision-allow-daily">
								{formatLives.format(initialDaily)} lives/day
							</strong>
							under the current assumptions.
						</li>
						<li>
							Move from theory and lobbying to monitored deployment, reporting,
							and real European operating data.
						</li>
						<li>
							Show Europe can prioritise measurable safety upside over procedural
							stall.
						</li>
					</ul>
				</article>

				<article class="decision-card decision-card--go">
					<span class="decision-card__kicker">Allow Today</span>
					<h3>What they risk</h3>
					<ul class="decision-list">
						<li>Owning the public fallout from any visible failure after approval.</li>
						<li>
							Needing strict audit, reporting, rollback, and operational guardrail
							rules from day one.
						</li>
						<li>
							Inviting immediate scrutiny from regulators, media, and incumbent
							industry players.
						</li>
					</ul>
				</article>

				<article class="decision-card decision-card--wait">
					<span class="decision-card__kicker">Keep Waiting</span>
					<h3>What they think they win</h3>
					<ul class="decision-list">
						<li>More committee time, more institutional cover, less short-term exposure.</li>
						<li>Extra time to refine conditions, reporting formats, and liability posture.</li>
						<li>
							One more buffer against criticism from groups that do not want rapid
							deployment.
						</li>
					</ul>
				</article>

				<article class="decision-card decision-card--wait">
					<span class="decision-card__kicker">Keep Waiting</span>
					<h3>What they risk</h3>
					<ul class="decision-list">
						<li>
							Leaving
							<strong id="decision-wait-annual">
								{formatLives.format(initialTotal)} lives/yr
							</strong>
							of illustrative upside frozen under <span id="decision-wait-scope">{initialScope.label}</span>.
						</li>
						<li>
							Adding about
							<strong id="decision-wait-daily">
								{formatLives.format(initialDaily)} lives/day
							</strong>
							to the live delay clock while nothing changes on the road.
						</li>
						<li>
							Surrendering operational learning to markets that move earlier while
							Europe keeps arguing in the abstract.
						</li>
						<li>
							Making delay itself the story, instead of the quality of the safety
							rules.
						</li>
					</ul>
				</article>
			</div>
		</section>

		<section class="panel">
			<div class="section-head">
				<p class="eyebrow">Committee delay</p>
				<h2>The reported EU schedule still uses May for a presentation and June for the earliest vote window</h2>
				<p>
					RDW already moved on 10 April 2026 after roughly 18 months of testing.
					RDW also says the remaining EU-wide path is Commission handling plus a
					member-state vote. Reporting published on 17 April 2026, citing a
					screenshot of a European Commission draft TCMV agenda, says the
					5 May 2026 meeting is only a Netherlands Article 39 update slot, not
					the vote itself.
				</p>
			</div>

			<div class="committee-grid">
				<article class="committee-card">
					<span class="committee-card__label">10 Apr 2026</span>
					<strong class="committee-card__value">Dutch approval landed</strong>
					<p>RDW issued national validity after more than 18 months of testing.</p>
				</article>
				<article class="committee-card">
					<span class="committee-card__label">5 May 2026</span>
					<strong class="committee-card__value">Reported next meeting</strong>
					<p>
						The reported draft agenda gives the Netherlands an Article 39 update
						slot only, not a vote, after a
						<strong>{formatWhole.format(reportedPresentationDelayDays)}-day wait</strong>
						from Dutch approval.
					</p>
				</article>
				<article class="committee-card">
					<span class="committee-card__label">30 Jun 2026</span>
					<strong class="committee-card__value">Earliest reported vote window</strong>
					<p>
						That is a <strong>{formatWhole.format(reportedVoteDelayDays)}-day gap</strong>
						from Dutch approval to the earliest reported formal committee vote.
					</p>
				</article>
				<article class="committee-card committee-card--hot">
					<span class="committee-card__label">Frozen by June</span>
					<strong class="committee-card__value" id="committee-frozen">
						{formatLives.format(initialReportedVoteDelay)}
						<span class="unit">lives</span>
					</strong>
					<p>
						Illustrative upside left on the table between 10 April 2026 and the
						earliest reported 30 June 2026 vote window under
						<span id="committee-scope">{initialScope.label}</span>.
					</p>
				</article>
			</div>

			<p class="footnote">
				RDW's own 10 April 2026 explanation confirms the Commission step and the
				member-state vote, but it does not publish committee dates. The 5 May
				2026 and 30 June 2026 dates above come from secondary reporting that
				cites a screenshot attributed to a European Commission draft agenda.
			</p>
		</section>

		<section class="panel">
			<div class="section-head">
				<p class="eyebrow">Country ladder</p>
				<h2>Where the frozen safety upside looks largest</h2>
				<p>
					This is a country-by-country ranking of the estimated annual safety
					upside currently left on the table. It is based on the latest full
					Eurostat fatality dataset plus 2024 BEV fleet share data, filtered
					through the selected approval scope.
				</p>
			</div>

			<table class="country-ladder">
				<caption>
					The Netherlands is marked separately because RDW says national approval
					is already live there. All other rows remain pending the EU-wide step
					RDW describes.
				</caption>
				<thead>
					<tr>
						<th scope="col">Rank</th>
						<th scope="col">Country</th>
						<th scope="col">Frozen annual upside</th>
						<th scope="col">Context</th>
						<th scope="col">Status</th>
					</tr>
				</thead>
				<tbody id="country-rows">
					{
						initialRanking.map((row, index) => (
							<tr>
								<td class="rank-cell">#{index + 1}</td>
								<td class="country-cell">
									<strong>{row.name}</strong>
									<span>{row.leadBody}</span>
								</td>
								<td>
									<span class="metric__value">
										{formatLives.format(row.estimatedLivesPerYear)}
										<span class="metric__unit">lives/yr</span>
									</span>
									<span class="metric__sub">
										Addressable fleet share:
										{formatLives.format(row.addressableFleetShare * 100)}%
									</span>
								</td>
								<td>
									<span class="metric__value">
										{formatWhole.format(row.fatalities2023)}
										<span class="metric__unit">deaths</span>
									</span>
									<span class="metric__sub">
										{formatLives.format(row.bevFleetShare2024)}% BEV fleet share in
										2024
									</span>
								</td>
								<td>
									<span class={renderStatusClass(row)}>
										{renderStatusLabel(row)}
									</span>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
			<p class="footnote">
				Using 2023 country fatality counts is deliberate: it is the latest full
				Eurostat country dataset. 2024 and 2025 Commission releases are newer
				but still preliminary at country detail level.
			</p>
		</section>

		<section class="panel">
			<div class="section-head">
				<p class="eyebrow">Institution map</p>
				<h2>Where responsibility actually sits today</h2>
				<p>
					The public argument gets weaker when it blurs the process. RDW's own
					text makes the bottleneck legible: the Dutch authority moved, the EU
					wide route still needs Commission handling and a member-state vote.
				</p>
			</div>

			<div class="institutions">
				{
					institutionTrack.map((item) => (
						<article class="institution-card">
							<span class="institution-card__stage">{item.stage}</span>
							<h3>{item.title}</h3>
							<p>{item.body}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="panel">
			<div class="section-head">
				<p class="eyebrow">Timeline</p>
				<h2>How the clock has moved so far</h2>
				<p>
					The sequence matters. RDW's testing window was long, the Dutch approval
					finally landed, and the EU-wide process still has not crossed the
					last-mile institutional gates.
				</p>
			</div>

			<div class="timeline">
				{
					timeline.map((item) => (
						<article class="timeline__item">
							<span class="timeline__date">{item.date}</span>
							<h3>{item.title}</h3>
							<p>{item.body}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="panel method-grid">
			<div class="method-card">
				<span class="method-card__kicker">Method</span>
				<h2 class="method__title">What the model is and what it is not</h2>
				<ul>
					{methodology.map((item) => <li>{item}</li>)}
				</ul>
			</div>

			<div class="method-card">
				<span class="method-card__kicker">Sources</span>
				<h2 class="sources__title">Sources and reporting</h2>
				<ul class="sources-list">
					{
						sources.map((source) => (
							<li>
								<a class="source-link" href={source.href}>
									{source.label}
								</a>
								<p>{source.note}</p>
							</li>
						))
					}
				</ul>
			</div>
		</section>
	</main>

	<script
		is:inline
		define:vars={{
			countries,
			defaultScenario,
			fleetScopes,
			approvalMoment: DUTCH_APPROVAL_MOMENT,
			processStartMoment: PROCESS_STARTED_MOMENT,
			reportedVoteDelayDays,
		}}
	>
		const teslaShareInput = document.querySelector("#tesla-share");
		const safetyGainInput = document.querySelector("#safety-gain");
		const scopeButtons = Array.from(document.querySelectorAll("[data-scope-key]"));
		const scopeCards = Array.from(document.querySelectorAll("[data-scope-card]"));
		const teslaShareValue = document.querySelector("#tesla-share-value");
		const safetyGainValue = document.querySelector("#safety-gain-value");
		const approvalScopeValue = document.querySelector("#approval-scope-value");
		const annualUpside = document.querySelector("#annual-upside");
		const annualUpsideScope = document.querySelector("#annual-upside-scope");
		const decisionAllowAnnual = document.querySelector("#decision-allow-annual");
		const decisionAllowDaily = document.querySelector("#decision-allow-daily");
		const decisionAllowScope = document.querySelector("#decision-allow-scope");
		const decisionWaitAnnual = document.querySelector("#decision-wait-annual");
		const decisionWaitDaily = document.querySelector("#decision-wait-daily");
		const decisionWaitScope = document.querySelector("#decision-wait-scope");
		const committeeFrozen = document.querySelector("#committee-frozen");
		const committeeScope = document.querySelector("#committee-scope");
		const sinceProcess = document.querySelector("#since-process");
		const sinceApproval = document.querySelector("#since-approval");
		const approvalDays = document.querySelector("#approval-days");
		const leaderCountry = document.querySelector("#leader-country");
		const leaderValue = document.querySelector("#leader-value");
		const leaderScope = document.querySelector("#leader-scope");
		const countryRows = document.querySelector("#country-rows");
		const counterWall = document.querySelector(".counter-wall");
		const impactStage = document.querySelector("#impact-stage");
		const impactStageStamp = document.querySelector("#impact-stage-stamp");
		const impactNextTimer = document.querySelector("#impact-next-timer");
		const realtimeProcessCounter = document.querySelector("#realtime-process-counter");
		const realtimeApprovalCounter = document.querySelector("#realtime-approval-counter");
		const realtimeRate = document.querySelector("#realtime-rate");
		const selectedScopeCopy = document.querySelector("#selected-scope-copy");

		const whole = new Intl.NumberFormat("en-US");
		const lives = new Intl.NumberFormat("en-US", {
			minimumFractionDigits: 1,
			maximumFractionDigits: 1,
		});

		const scopesByKey = Object.fromEntries(
			fleetScopes.map((scope) => [scope.key, scope]),
		);
		const secondsPerYear = 365 * 24 * 60 * 60;
		let annualUpsideValue = 0;
		let currentScopeKey = defaultScenario.approvalScopeKey;
		let lastProcessWhole = null;
		let impactResetTimer;

		const compute = (country, scenario) => {
			const scope = scopesByKey[scenario.approvalScopeKey] ?? fleetScopes[fleetScopes.length - 1];
			const addressableFleetShare =
				(country.bevFleetShare2024 / 100) *
				(scenario.teslaShareWithinBev / 100) *
				(scope.coverageShare / 100);
			const estimatedLivesPerYear =
				country.fatalities2023 *
				addressableFleetShare *
				(scenario.safetyGain / 100);

			return {
				...country,
				addressableFleetShare,
				estimatedLivesPerYear,
			};
		};

		const elapsedSeconds = (from) =>
			Math.max(0, (Date.now() - Date.parse(from)) / 1000);

		const formatCountdown = (secondsRemaining) => {
			if (!Number.isFinite(secondsRemaining) || secondsRemaining <= 0) {
				return "now";
			}

			const days = Math.floor(secondsRemaining / 86400);
			const hours = Math.floor((secondsRemaining % 86400) / 3600);
			const minutes = Math.floor((secondsRemaining % 3600) / 60);

			if (days >= 1) {
				return `${days}d ${hours}h`;
			}

			if (hours >= 1) {
				return `${hours}h ${minutes}m`;
			}

			return `${Math.max(1, minutes)}m`;
		};

		const computeScopeResults = (baseScenario) =>
			fleetScopes.map((scope) => {
				const scenario = { ...baseScenario, approvalScopeKey: scope.key };
				const rows = countries
					.map((country) => compute(country, scenario))
					.sort((left, right) => right.estimatedLivesPerYear - left.estimatedLivesPerYear);

				return {
					...scope,
					rows,
					total: rows.reduce((sum, row) => sum + row.estimatedLivesPerYear, 0),
				};
			});

		const updateScopeCards = (scopeResults) => {
			const latestOnlyTotal =
				scopeResults.find((scope) => scope.key === "latest-only")?.total ?? 1;
			const activeScope = scopesByKey[currentScopeKey] ?? fleetScopes[fleetScopes.length - 1];

			approvalScopeValue.textContent = activeScope.label;
			selectedScopeCopy.textContent = activeScope.label;
			annualUpsideScope.textContent = activeScope.label;
			leaderScope.textContent = activeScope.label;

			scopeButtons.forEach((button) => {
				const active = button.dataset.scopeKey === currentScopeKey;
				button.classList.toggle("is-active", active);
				button.setAttribute("aria-pressed", active ? "true" : "false");
			});

			scopeCards.forEach((card) => {
				card.classList.toggle("is-active", card.dataset.scopeCard === currentScopeKey);
			});

			scopeResults.forEach((scope) => {
				const value = document.querySelector(`#scope-${scope.key}-value`);
				const multiplier = document.querySelector(`#scope-${scope.key}-multiplier`);

				value.innerHTML = `${lives.format(scope.total)} <span class="unit">lives/yr</span>`;
				multiplier.textContent =
					scope.key === "latest-only"
						? "Baseline"
						: `${lives.format(scope.total / latestOnlyTotal)}x newest-only`;
			});
		};

		const triggerImpact = (countDelta) => {
			const wholeDelta = Math.max(1, Math.floor(countDelta));

			impactStageStamp.textContent = `+${wholeDelta}`;
			impactStage.classList.remove("is-live");
			counterWall.classList.remove("is-live");
			void impactStage.offsetWidth;
			impactStage.classList.add("is-live");
			counterWall.classList.add("is-live");

			window.clearTimeout(impactResetTimer);
			impactResetTimer = window.setTimeout(() => {
				impactStage.classList.remove("is-live");
				counterWall.classList.remove("is-live");
			}, 900);
		};

		const updateDecisionCards = (total) => {
			const daily = total / 365;
			const activeScope = scopesByKey[currentScopeKey] ?? fleetScopes[fleetScopes.length - 1];

			decisionAllowAnnual.textContent = `${lives.format(total)} lives/yr`;
			decisionAllowDaily.textContent = `${lives.format(daily)} lives/day`;
			decisionAllowScope.textContent = activeScope.label;
			decisionWaitAnnual.textContent = `${lives.format(total)} lives/yr`;
			decisionWaitDaily.textContent = `${lives.format(daily)} lives/day`;
			decisionWaitScope.textContent = activeScope.label;
		};

		const updateCommitteeDelay = (total) => {
			const activeScope = scopesByKey[currentScopeKey] ?? fleetScopes[fleetScopes.length - 1];
			const frozenByVote = (total / 365) * reportedVoteDelayDays;

			committeeFrozen.innerHTML = `${lives.format(frozenByVote)} <span class="unit">lives</span>`;
			committeeScope.textContent = activeScope.label;
		};

		const updateRealtimeCounters = () => {
			const approvalSeconds = elapsedSeconds(approvalMoment);
			const processSeconds = elapsedSeconds(processStartMoment);
			const annualPerSecond = annualUpsideValue / secondsPerYear;
			const approvalCount = annualPerSecond * approvalSeconds;
			const processCount = annualPerSecond * processSeconds;
			const processWhole = Math.floor(processCount);
			const secondsUntilNextImpact =
				annualPerSecond > 0
					? (processWhole + 1 - processCount) / annualPerSecond
					: Number.POSITIVE_INFINITY;

			realtimeApprovalCounter.textContent = lives.format(approvalCount);
			realtimeProcessCounter.textContent = lives.format(processCount);
			realtimeRate.textContent = lives.format(annualUpsideValue / 365);
			impactNextTimer.textContent = formatCountdown(secondsUntilNextImpact);
			sinceApproval.innerHTML = `${lives.format(approvalCount)} <span class="unit">lives</span>`;
			sinceProcess.innerHTML = `${lives.format(processCount)} <span class="unit">lives</span>`;
			approvalDays.textContent = whole.format(Math.floor(approvalSeconds / 86400));

			if (lastProcessWhole !== null && processWhole > lastProcessWhole) {
				triggerImpact(processWhole - lastProcessWhole);
			}

			lastProcessWhole = processWhole;
		};

		const statusLabel = (approval) =>
			approval === "national-approval" ? "Live in NL" : "Pending EU vote";

		const statusClass = (approval) =>
			approval === "national-approval"
				? "status-badge status-badge--live"
				: "status-badge status-badge--pending";

		const render = () => {
			const baseScenario = {
				teslaShareWithinBev: Number(teslaShareInput.value),
				safetyGain: Number(safetyGainInput.value),
			};

			teslaShareValue.textContent = `${baseScenario.teslaShareWithinBev}%`;
			safetyGainValue.textContent = `${baseScenario.safetyGain}%`;

			const scopeResults = computeScopeResults(baseScenario);
			const selectedResult =
				scopeResults.find((scope) => scope.key === currentScopeKey) ??
				scopeResults[scopeResults.length - 1];

			const rows = selectedResult.rows;
			const total = selectedResult.total;
			const leader = rows[0];
			annualUpsideValue = total;

			updateScopeCards(scopeResults);
			updateDecisionCards(total);
			updateCommitteeDelay(total);
			annualUpside.innerHTML = `${lives.format(total)} <span class="unit">lives/yr</span>`;
			leaderCountry.textContent = leader.name;
			leaderValue.textContent = lives.format(leader.estimatedLivesPerYear);
			updateRealtimeCounters();

			countryRows.innerHTML = rows
				.map(
					(row, index) => `
						<tr>
							<td class="rank-cell">#${index + 1}</td>
							<td class="country-cell">
								<strong>${row.name}</strong>
								<span>${row.leadBody}</span>
							</td>
							<td>
								<span class="metric__value">${lives.format(row.estimatedLivesPerYear)} <span class="metric__unit">lives/yr</span></span>
								<span class="metric__sub">Addressable fleet share: ${lives.format(row.addressableFleetShare * 100)}%</span>
							</td>
							<td>
								<span class="metric__value">${whole.format(row.fatalities2023)} <span class="metric__unit">deaths</span></span>
								<span class="metric__sub">${lives.format(row.bevFleetShare2024)}% BEV fleet share in 2024</span>
							</td>
							<td>
								<span class="${statusClass(row.approval)}">${statusLabel(row.approval)}</span>
							</td>
						</tr>
					`,
				)
				.join("");
		};

		scopeButtons.forEach((button) => {
			button.addEventListener("click", () => {
				currentScopeKey = button.dataset.scopeKey;
				render();
			});
		});
		teslaShareInput.addEventListener("input", render);
		safetyGainInput.addEventListener("input", render);
		render();
		window.setInterval(updateRealtimeCounters, 250);
	</script>
</Layout>
