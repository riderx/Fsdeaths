---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Europe's FSD Delay Ledger",
	description = "A source-backed tracker for Europe's FSD approval bottleneck.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=car1" />
		<link rel="icon" type="image/png" href="/favicon.png?v=car1" sizes="128x128" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#140c08" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
